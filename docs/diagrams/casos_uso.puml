@startuml casos_uso
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam shadowing false
skinparam ActorBorderColor #555555
skinparam UsecaseBorderColor #3B82F6
skinparam UsecaseBackgroundColor #EFF6FF
skinparam UsecaseFontSize 11

title GestorCOC - Diagrama de Casos de Uso

' ─── Actores ───────────────────────────────
actor "Solo Visualizacion\n(OP_VIEWER)" as Viewer
actor "Operador de Camaras\n(OP_CONTROL)" as Control
actor "Operador Basico\n(OP_EXTRACTION)" as Extraction
actor "Administrador\n(ADMIN)" as Admin

' Herencia de actores
Viewer <|-- Control
Control <|-- Extraction
Extraction <|-- Admin

' ─── Sistema ───────────────────────────────
rectangle "GestorCOC" {

    ' --- Activos ---
    package "Gestion de Activos" {
        usecase "Ver inventario\n(Unidades, Sistemas,\nServidores, Camaras)" as UC_VerActivos
        usecase "ABM Activos\n(crear/editar/eliminar)" as UC_ABMActivos
        usecase "Gestionar\nequipamiento\ncamarografo" as UC_Gear
    }

    ' --- Novedades ---
    package "Novedades Operativas" {
        usecase "Reportar novedad\n(falla/evento)" as UC_ReportarNovedad
        usecase "Actualizar estado\n(OPEN→IN_PROGRESS→CLOSED)" as UC_EstadoNovedad
        usecase "Vincular ticket\nexterno DGT/CCO" as UC_TicketExterno
    }

    ' --- Registros Filmicos ---
    package "Registros Filmicos" {
        usecase "Crear registro\nfilmico" as UC_CrearRegistro
        usecase "Registrar backup\ny hash de evidencia" as UC_Backup
        usecase "Verificar registro\n(Integridad)" as UC_VerificarIntegridad
        usecase "Descargar certificado\nde verificacion PDF" as UC_Certificado
    }

    ' --- Integridad ---
    package "Verificacion de Integridad" {
        usecase "Calcular hash\nde archivo (local)" as UC_Hash
        usecase "Generar informe\nPDF de hashes" as UC_InformePDF
    }

    ' --- Informes ---
    package "Informes de Video" {
        usecase "Completar wizard\nde informe" as UC_Wizard
        usecase "Mejorar texto\ncon IA" as UC_MejorarIA
        usecase "Generar DOCX\ndel informe" as UC_GenerarDOCX
    }

    ' --- Hechos ---
    package "Bitacora de Hechos" {
        usecase "Registrar hecho\noperativo" as UC_Hecho
        usecase "Vincular camara\nal hecho" as UC_HechoCamara
    }

    ' --- Personal ---
    package "Gestion de Personal" {
        usecase "ABM Personal\ninterno" as UC_ABMPersonal
        usecase "Ver personal\nexterno" as UC_PersonalExterno
    }

    ' --- Dashboard ---
    package "Dashboard" {
        usecase "Ver KPIs y\ngraficas" as UC_KPIs
        usecase "Ver mapa\ngeorreferenciado" as UC_Mapa
    }
}

' ─── Relaciones Viewer ───────────────────
Viewer --> UC_VerActivos
Viewer --> UC_KPIs
Viewer --> UC_Mapa

' ─── Relaciones Control ──────────────────
Control --> UC_ReportarNovedad
Control --> UC_EstadoNovedad
Control --> UC_TicketExterno
Control --> UC_Hecho
Control --> UC_HechoCamara

' ─── Relaciones Extraction ───────────────
Extraction --> UC_CrearRegistro
Extraction --> UC_Backup
Extraction --> UC_Hash
Extraction --> UC_InformePDF
Extraction --> UC_Wizard
Extraction --> UC_MejorarIA
Extraction --> UC_GenerarDOCX

' ─── Relaciones Admin (exclusivas) ─────────
Admin --> UC_ABMActivos
Admin --> UC_ABMPersonal
Admin --> UC_PersonalExterno
Admin --> UC_Gear
Admin --> UC_VerificarIntegridad
Admin --> UC_Certificado

' ─── Includes / Extends ────────────────────
UC_Backup ..> UC_Hash : <<include>>
UC_VerificarIntegridad ..> UC_Certificado : <<include>>
UC_MejorarIA ..> UC_Wizard : <<extend>>

@enduml
